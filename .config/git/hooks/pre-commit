#!/usr/bin/env bash

# git-secrets: scan for AWS keys/secrets
git secrets --pre_commit_hook -- "$@"

# trufflehog runs at pre-push (see ~/.config/git/hooks/pre-push)

# --- delegate to repo-local hook ---
_local="$(git rev-parse --git-dir)/hooks/pre-commit"
if [ -x "$_local" ]; then
    "$_local" "$@" || exit $?
fi
