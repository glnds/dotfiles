[user]
  name = Gert Leenders
  email = leenders.gert@gmail.com
[core]
  editor = nvim
  autocrlf = input
  whitespace = space-before-tab, trailing-space
  excludesfile = ~/.config/git/ignore
  pager = delta
[interactive]
  diffFilter = delta --color-only
[delta]
  navigate = true
  dark = true
  side-by-side = true
  line-numbers = true
  syntax-theme = base16
[credential]
  helper = osxkeychain
[color]
  ui = auto
[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green
[color "diff"]
  meta = yellow bold
  frag = magenta bold
  old = red bold
  new = green bold
[merge]
  tool = vimdiff
  log = true
  conflictstyle = zdiff3
  ff = false
[push]
  default = simple
  followTags = true
[difftool "vimdiff"]
  cmd = vimdiff \"$LOCAL\" \"$REMOTE\"
  path = 
[mergetool "vimdiff"]
  cmd = vimdiff \"$LOCAL\" \"$MERGED\" \"$REMOTE\"
[gc "refs/remotes/*"]
  reflogExpire = 6 months
  reflogExpireUnreachable = 3 months
[branch]
  autosetuprebase = always
[filter "lfs"]
  clean = git-lfs clean %f
  smudge = git-lfs smudge %f
  required = true
[pull]
  ff = only
  rebase = true
[url "git@bitbucket.org:"]
  insteadOf = https://bitbucket.org/
[init]
	defaultBranch = master
[includeIf "gitdir:~/source/dpg/"]
  path = ~/.gitconfig-github-dpg
[url "git@github-dpgmedia:DPG-Media-Community/"]
  insteadOf = https://github.com/DPG-Media-Community/
  insteadOf = git@github.com:DPG-Media-Community/
[url "git@github.com:"]
	insteadOf = https://github.com/
